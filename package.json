{
  "name": "@openparachute/agents",
  "version": "0.0.1",
  "description": "Framework for building stateful AI agents on Cloudflare with native Parachute Vault integration.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare.d.ts",
      "import": "./dist/cloudflare.js"
    },
    "./triggers/webhook": {
      "types": "./dist/triggers/webhook.d.ts",
      "import": "./dist/triggers/webhook.js"
    },
    "./adapters/node": {
      "types": "./dist/adapters/node.d.ts",
      "import": "./dist/adapters/node.js"
    },
    "./connectors": {
      "types": "./dist/connectors/index.d.ts",
      "import": "./dist/connectors/index.js"
    },
    "./sqlite": {
      "types": "./dist/conversation-store-sqlite.d.ts",
      "import": "./dist/conversation-store-sqlite.js"
    },
    "./scheduler-node": {
      "types": "./dist/scheduler-node.d.ts",
      "import": "./dist/scheduler-node.js"
    },
    "./run-log-sqlite": {
      "types": "./dist/run-log-sqlite.d.ts",
      "import": "./dist/run-log-sqlite.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "agents": "^0.0.80",
    "ai": "^4.0.0",
    "croner": "^10.0.1",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.90.0"
  }
}
